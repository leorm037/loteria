{# templates/registration/register.html.twig #}
{% extends 'base.html.twig' %}

{% block breadcrumb %}
    <li class="breadcrumb-item active"><i class="bi bi-person-plus"></i> Cadastrar</li>
    {% endblock %}

{% block title %}{{ parent() }} :: Cadastrar{% endblock %}

{% block body %}
    {{ form_start(registrationForm) }}
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8 col-md-10 col-12">
            <div class="card">
                <div class="card-header bg-gradient">
                    <h1 class="h4 my-0">Cadastrar</h1>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-md-6">
                            {{ form_row(registrationForm.nome) }}
                        </div>
                        <div class="col-12 col-md-6">
                            {{ form_row(registrationForm.celular) }}
                        </div>
                        <div class="col-12">
                            <div class="row row-cols-md-2 row-cols-1">
                                {{ form_row(registrationForm.email) }}
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="row row-cols-md-2 row-cols-1">
                                {{ form_row(registrationForm.plainPassword) }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-gradient d-flex justify-content-between">
                    <a class="btn btn-secondary bg-gradient btn-sm" href="{{ path('app_register') }}"><i class="fa-solid fa-broom"></i> Limpar</a>
                    <button type="submit" class="btn btn-primary bg-gradient btn-sm"><i class="bi bi-floppy"></i> Salvar</button>
                </div>
            </div>
        </div>
    </div>
    {{ form_end(registrationForm) }}
{% endblock %}
