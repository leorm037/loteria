{% extends 'base.html.twig' %}

{% block title %}Loteria{% endblock %}

{% block body %}
    <h1>Loteria</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ loterium.id }}</td>
            </tr>
            <tr>
                <th>Api</th>
                <td>{{ loterium.api }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ loterium.slug }}</td>
            </tr>
            <tr>
                <th>Nome</th>
                <td>{{ loterium.nome }}</td>
            </tr>
            <tr>
                <th>Dezena</th>
                <td>{{ loterium.dezena ? loterium.dezena|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Premiar</th>
                <td>{{ loterium.premiar ? loterium.premiar|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Marcar</th>
                <td>{{ loterium.marcar ? loterium.marcar|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ loterium.createdAt ? loterium.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ loterium.updatedAt ? loterium.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Logo</th>
                <td>{{ loterium.logo }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_loteria_index') }}">back to list</a>

    <a href="{{ path('app_loteria_edit', {'id': loterium.id}) }}">edit</a>

    {{ include('loteria/_delete_form.html.twig') }}
{% endblock %}
