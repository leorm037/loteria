{% extends 'base.html.twig' %}

{% block title %}Loteria index{% endblock %}

{% block body %}
    <h1>Loteria index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Api</th>
                <th>Slug</th>
                <th>Nome</th>
                <th>Dezena</th>
                <th>Premiar</th>
                <th>Marcar</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>Logo</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for loterium in loterias %}
            <tr>
                <td>{{ loterium.id }}</td>
                <td>{{ loterium.api }}</td>
                <td>{{ loterium.slug }}</td>
                <td>{{ loterium.nome }}</td>
                <td>{{ loterium.dezena ? loterium.dezena|json_encode : '' }}</td>
                <td>{{ loterium.premiar ? loterium.premiar|json_encode : '' }}</td>
                <td>{{ loterium.marcar ? loterium.marcar|json_encode : '' }}</td>
                <td>{{ loterium.createdAt ? loterium.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ loterium.updatedAt ? loterium.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ loterium.logo }}</td>
                <td>
                    <a href="{{ path('app_loteria_show', {'id': loterium.id}) }}">show</a>
                    <a href="{{ path('app_loteria_edit', {'id': loterium.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_loteria_new') }}">Create new</a>
{% endblock %}
