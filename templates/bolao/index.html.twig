{# templates/bolao/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} :: Bolão{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active"><i class="fa-solid fa-people-group"></i> Bolão</li>
{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <div><h1 class="h4 m-0"><i class="fa-solid fa-people-group"></i> Bolão</h1></div>
                <div>
                    <a href="{{ path('app_bolao_new') }}" class="btn btn-primary btn-sm bg-gradient shadow-sm"><i class="bi bi-plus"></i> Novo</a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Loteria</th>
                            <th>Concurso</th>
                            <th>Apostadores</th>
                            <th>Apostas</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody class="table-group-divider">
                        {% for item in boloes %}
                            <tr>
                                <td>{{ item.bolao.nome }}</td>
                                <td>{{ item.bolao.loteria.nome }}</td>
                                <td class="text-end">{{ item.bolao.concurso.numero }}</td>
                                <td class="text-end">0</td>
                                <td class="text-end">0</td>
                                <td class="text-center">
                                    <a href="{{ path('app_bolao_edit', {'id': item.bolao.id}) }}" class="btn btn-sm btn-primary shadow-sm"><i class="bi bi-pencil-square"></i> <span class="d-none d-lg-inline-block">Alterar</span></a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center">Nenhum registro encontrado</td>
                            </tr>
                        </tbody>
                    {% endfor %}
                </table>
            </div>
        </div>
        <div class="card-footer">

        </div>
    </div>
{% endblock %}
