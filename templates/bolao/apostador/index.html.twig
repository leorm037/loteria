{# templates/bolao/apostador/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} :: Bolão :: Apostadores{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a data-loading="true" href="{{ path('app_bolao_index') }}" class="text-decoration-none"><i class="fa-solid fa-people-group"></i> Bolão</a></li>
    <li class="breadcrumb-item active"><i class="bi bi-people"></i> Apostador</li>
    {% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <div><h1 class="h4 m-0"><i class="bi bi-people"></i></i> Apostadores</h1></div>
                <div>
                    <a data-loading="true" href="{{ path('app_bolao_apostador_new', {'id': bolao.id}) }}" class="btn btn-primary btn-sm bg-gradient shadow-sm">
                        <i class="bi bi-plus"></i> {{ 'btn.new'|trans({}, 'label') }}
                    </a>
                </div>
            </div>
        </div>
        {{ include('bolao/_bolao.html.twig') }}
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>E-mail</th>
                            <th>Celular</th>
                            <th>Pago</th>
                            <th>Quantidade de cotas</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody class="table-group-divider">
                        {% for apostador in apostadores %}
                            <tr>
                                <td>{{ apostador.nome }}</td>
                                <td>{{ apostador.email }}</td>
                                <td>{{ apostador.celular }}</td>
                                <td>{{ apostador.ispago ? 'Sim' : 'Não' }}</td>
                                <td class="text-end">{{ apostador.quantidadeCota }}</td>
                                <td class="text-center">
                                    {% if apostador.comprovante %}
                                        <a href="{{ path('app_bolao_apostador_download', {'id': apostador.id}) }}" class="btn btn-sm btn-secondary shadow-sm">
                                            <i class="bi bi-file-arrow-down"></i> <span class="d-none d-lg-inline-block">Comprovante</span>
                                        </a>
                                    {% endif %}
                                    <a data-loading="true" href="{{ path('app_bolao_apostador_edit', {'id': apostador.id}) }}" class="btn btn-sm btn-secondary shadow-sm">
                                        <i class="bi bi-pencil-square"></i> <span class="d-none d-lg-inline-block">Alterar</span>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center">Nenhum registro encontrado</td>
                            </tr>
                        </tbody>
                    {% endfor %}
                </table>
            </div>
        </div>
        <div class="card-footer bg-gradient text-end">
            <div class="d-flex justify-content-between">
                <div>
                    <a class="btn btn-outline-secondary bg-gradient btn-sm" href="{{ path('app_bolao_index', {'id': bolao.id}) }}">
                        <i class="bi bi-arrow-left"></i> Voltar
                    </a>
                </div>
                <div>
                    Total de registros enconstrados: {{ apostadores|length }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
