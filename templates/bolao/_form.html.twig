{# bolao/_form.html.twig #}
{{ form_errors(form) }}
<div class="row">
    <div class="col-12 col-md-6">
        {{ form_row(form.loteria) }}
    </div>
    <div class="col-12 col-md-6">
        {{ form_row(form.concursoNumero) }}
    </div>
    <div class="col-12 col-md-6">
        {{ form_row(form.nome) }}
    </div>
    <div class="col-12 col-md-6">
        {{ form_row(form.valorCota) }}
    </div>
    <div class="col-12">
        <div class="row">
            {% if bolao.comprovante %}
                <div class="col-12 col-lg-10 col-md-9">
            {% else %}
                <div class="col-12">
            {% endif %}
                {{ form_row(form.comprovanteAposta) }}
            </div>
            {% if bolao.comprovante %}
                <div class="col-12 col-lg-2 col-md-3">
                    <div class="mb-3 d-grid">
                        <label for="comprovante" class="form-label">Comprovante</label>
                        <a href="{{ path('app_bolao_download', {'id': app.request.get('id')}) }}" class="btn btn-secondary shadow-sm">
                            <i class="bi bi-file-arrow-down"></i> Download
                        </a>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>    
</div>