{# templates/bolao/aposta/import.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} :: Bolão :: Aposta :: Importar{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a data-loading="true" href="{{ path('app_bolao_index') }}" class="text-decoration-none"><i class="fa-solid fa-people-group"></i> Bolão</a></li>
    <li class="breadcrumb-item"><a data-loading="true" href="{{ path('app_bolao_aposta_index', {'id': bolao.id}) }}" class="text-decoration-none"><i class="bi bi-ticket-perforated"></i> Aposta</a></li>
    <li class="breadcrumb-item active"><i class="bi bi-box-arrow-in-down"></i> Importar</li>
    {% endblock %}

{% block body %}
    {{ form_start(form, {'attr': {'data-loading': 'true'}}) }}
    {{ form_errors(form) }}
    <div class="card shadow-sm">
        <div class="card-header">
            <h1 class="h4 m-0"><i class="bi bi-people"></i> Novo apostador</h1>
        </div>
        {{ include('bolao/_bolao.html.twig') }}
        <div class="card-body">
            {{ form_row(form.fileCsv) }}
        </div>
        <div class="card-footer bg-gradient d-flex justify-content-between">
            <div>
                <a class="btn btn-outline-secondary bg-gradient btn-sm" href="{{ path('app_bolao_apostador_index', {'id': bolao.id}) }}"><i class="bi bi-arrow-left"></i> Voltar</a>
            </div>
            <div>
                <button type="reset" class="btn btn-secondary bg-gradient btn-sm"><i class="fa-solid fa-broom"></i> Limpar</button>
                <button type="submit" class="btn btn-primary bg-gradient btn-sm"><i class="bi bi-floppy"></i> Salvar</button>
            </div>
        </div>
    </div>
    {{ form_end(form) }}
{% endblock %}
