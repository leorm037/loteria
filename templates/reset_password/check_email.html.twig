{# templates/reset_password/check_email.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} :: Recuperar senha{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active"><i class="bi bi-key"></i> Recuperar senha</li>
{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-header">
            <h1 class="h4 m-0"><i class="bi bi-key"></i> Recuperar senha</h1>
        </div>
        <div class="card-body">
            <p>
                Se existir uma conta que corresponda ao seu e-mail, então foi
                enviado um e-mail contendo um link que você pode usar para
                redefinir sua senha. Este link irá expirar em 
                {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>
            <p>
                Se você não receber um e-mail, verifique sua caixa spam ou 
                <a href="{{ path('app_forgot_password_request') }}">tente novamente</a>.
            </p>
        </div>
        <div class="card-footer bg-gradient text-end">
            <a href="{{ path('app_home') }}" data-loading="true" class="btn btn-primary bg-gradient btn-sm"><i class="fa-solid fa-clover"></i> Página incial</a>
        </div>
    </div>
{% endblock %}
