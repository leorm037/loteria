{# templates/reset_password/email.html.twig #}
<div style="background-color: #EAECEE; width: 100%; height: 100%">
    <div style="padding-top: 1px; margin-left: auto; margin-right: auto; width: 640px; text-align: center">
        <h1 style="font-family: Ubuntu, Verdana; font-size: 20pt; color: #ABB2B9;">Bolão da família</h1>
    </div>
    <div style="margin-left: auto; margin-right: auto; width: 640px; background-color: #FFFFFF; border-radius: 25px;">
        <div>
            <img width="640" height="200" alt="🍀" src="data:image/png;base64," style="border-radius: 25px 25px 0px 0px;">
        </div>
        <div style="margin-left: 30px; margin-right: 30px; padding-bottom: 20px; font-family: Ubuntu, Verdana">
            <h1 style="font-size: 16pt; margin-top: 30px; margin-bottom: 30px;">Olá!</h1>

            <p>
                Para trocar a seu senha, acesse o link:
            </p>
            <p>
                <a href="{{ url('app_reset_password', {token: resetToken.token}) }}">{{ url('app_reset_password', {token: resetToken.token}) }}</a>
            </p>
            <p>
                Este link expira em {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
            </p>

            <p style="margin-top: 50px;">
                Obrigado!
            </p>
        </div>
    </div>
    <div style="margin-top: 20px; height: 50px; text-align: center;">
        <a style="font-family: Ubuntu, Verdana; color: #ABB2B9;" href="{{ url('app_home') }}">🍀️ Visite site o Bolão da família 🍀</a>
    </div>
</div>